@page "{id}"
@model VisualAcademy.Pages.Tenants.DetailsModel
@{
    ViewData["Title"] = "Details";
}

<h1>@ViewData["Title"]</h1>

@if (Model.TenantModel is null)
{
    <div class="alert alert-warning">
        Tenant not found.
    </div>

    <div>
        <a asp-page="./Index">Back to List</a>
    </div>
}
else
{
    var tenant = Model.TenantModel;

    <div>
        <h4>TenantModel</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.ConnectionString)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.ConnectionString)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.Name)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.AuthenticationHeader)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.AuthenticationHeader)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.AccountID)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.AccountID)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.GSConnectionString)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.GSConnectionString)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.ReportWriterURL)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.ReportWriterURL)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.BadgePhotoType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.BadgePhotoType)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(_ => tenant.PortalName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => tenant.PortalName)
            </dd>
        </dl>
    </div>

    <div>
        <a asp-page="./Index">Back to List</a>
    </div>
}