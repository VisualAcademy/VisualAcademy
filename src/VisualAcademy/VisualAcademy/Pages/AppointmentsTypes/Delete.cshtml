@page "{id?}"
@model VisualAcademy.Pages.AppointmentsTypes.DeleteModel
@{
    ViewData["Title"] = "Delete";
}

<h1>@ViewData["Title"]</h1>

@if (Model.AppointmentType == null)
{
    <div class="alert alert-warning">
        삭제할 데이터를 찾을 수 없습니다.
    </div>

    <div class="form-group">
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </div>
}
else
{
    <h3>Are you sure you want to delete this?</h3>
    <div>
        <h4>AppointmentTypeModel</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AppointmentType!.AppointmentTypeName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AppointmentType!.AppointmentTypeName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AppointmentType!.IsActive)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AppointmentType!.IsActive)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AppointmentType!.DateCreated)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AppointmentType!.DateCreated)
            </dd>
        </dl>

        <form method="post">
            <input type="hidden" name="AppointmentType.Id" value="@Model.AppointmentType.Id" />
            <input type="hidden" asp-for="TenantId" />

            <div class="form-group">
                <input type="submit" value="Delete" class="btn btn-danger" /> |
                <a asp-page="./Index">Back to List</a>
            </div>
        </form>
    </div>
}