@page
@model ProfilePictureUploadModel
@{
    ViewData["Title"] = "Profile Picture Upload";
    ViewData["ActivePage"] = ManageNavPages.Index;
    var uploadProfilePictureUrl = Url.Page(null, "UploadProfilePicture");
}

<div class="container">
    <h4>@ViewData["Title"]</h4>
    <partial name="_StatusMessage" model="Model.StatusMessage" />

    <form id="profile-picture-form" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Input.ProfilePicture" style="width: 100%;"></label>

            <div class="profile-picture-container">
                <div class="profile-picture-wrapper">
                    @if (Model.Input.ProfilePicture != null && Model.Input.ProfilePicture.Length > 0)
                    {
                        <img id="profilePicture"
                             class="profile-picture-preview"
                             src="data:image/*;base64,@Convert.ToBase64String(Model.Input.ProfilePicture)"
                             alt="Profile Picture" />

                        <div id="profilePicturePlaceholder"
                             class="profile-picture-placeholder"
                             style="display:none;">
                            <span class="oi oi-camera-slr"></span>
                        </div>
                    }
                    else
                    {
                        <img id="profilePicture"
                             class="profile-picture-preview"
                             src=""
                             alt="Profile Picture"
                             style="display:none;" />

                        <div id="profilePicturePlaceholder" class="profile-picture-placeholder">
                            <span class="oi oi-camera-slr"></span>
                        </div>
                    }

                    <div class="profile-picture-actions"
                         onmousedown="event.preventDefault(); event.stopPropagation();"
                         onclick="event.stopPropagation();">

                        <button type="button"
                                id="profileUploadButton"
                                class="profile-picture-action-button"
                                title="Upload Photo"
                                onclick="openProfileFileUpload(event)">
                            <i class="material-icons">file_upload</i>
                        </button>

                        <button type="button"
                                id="profileCameraButton"
                                class="profile-picture-action-button"
                                title="Take Photo"
                                onclick="openProfileWebcamCapture(event)">
                            <i class="material-icons">photo_camera</i>
                        </button>
                    </div>
                </div>

                <input type="file"
                       id="profilePictureFileInput"
                       name="profilePicture"
                       accept=".png,.jpg,.jpeg,.gif,.tif,.webp"
                       class="hidden-profile-file-input"
                       onchange="uploadProfilePictureFromFile(this)" />
            </div>

            <span asp-validation-for="Input.ProfilePicture" class="text-danger"></span>
            <div id="profilePictureMessage" class="profile-picture-message"></div>
        </div>
    </form>
</div>

<div id="profileWebcamModal" class="profile-webcam-modal" style="display:none;">
    <div class="profile-webcam-backdrop" onclick="closeProfileWebcamCapture()"></div>

    <div class="profile-webcam-content" onclick="event.stopPropagation();">
        <div class="profile-webcam-header">
            <h4>Take Photo</h4>
            <button type="button"
                    class="profile-webcam-close-button"
                    onclick="closeProfileWebcamCapture()">
                ×
            </button>
        </div>

        <div class="profile-webcam-body">
            <video id="profileWebcamVideo"
                   class="profile-webcam-video"
                   autoplay
                   playsinline>
            </video>

            <canvas id="profileWebcamCanvas"
                    width="480"
                    height="360"
                    style="display:none;">
            </canvas>

            <img id="profileWebcamPreview"
                 class="profile-webcam-preview"
                 style="display:none;"
                 alt="Captured Profile Picture" />

            <div id="profileWebcamMessage" class="profile-webcam-message"></div>
        </div>

        <div class="profile-webcam-footer">
            <button type="button"
                    class="btn btn-secondary"
                    onclick="closeProfileWebcamCapture()">
                Cancel
            </button>

            <button type="button"
                    id="profileCaptureButton"
                    class="btn btn-primary"
                    onclick="captureProfileWebcamPhoto()">
                Capture
            </button>

            <button type="button"
                    id="profileWebcamUploadButton"
                    class="btn btn-success"
                    onclick="uploadProfileWebcamPhoto()">
                Upload Photo
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
        .profile-picture-container {
            position: relative;
            display: inline-block;
        }

        .profile-picture-wrapper {
            position: relative;
            width: 350px;
            height: 350px;
        }

        .profile-picture-preview {
            width: 350px;
            height: 350px;
            object-fit: cover;
            border-radius: 50%;
            border: 1px solid #ddd;
        }

        .profile-picture-placeholder {
            width: 350px;
            height: 350px;
            border-radius: 50%;
            border: 1px solid #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 64px;
            color: #777;
            background: #f7f7f7;
        }

        .profile-picture-actions {
            position: absolute;
            right: 20px;
            bottom: 20px;
            display: flex;
            gap: 10px;
            z-index: 10;
        }

        .profile-picture-action-button {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: none;
            background: #0d6efd;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(0, 0, 0, .25);
            cursor: pointer;
        }

        .profile-picture-action-button:hover {
            background: #0b5ed7;
        }

        .profile-picture-action-button:disabled {
            opacity: .65;
            cursor: not-allowed;
        }

        .hidden-profile-file-input {
            display: none !important;
            visibility: hidden !important;
            width: 0 !important;
            height: 0 !important;
            opacity: 0 !important;
            position: absolute !important;
            left: -9999px !important;
            top: -9999px !important;
            pointer-events: none !important;
        }

        .profile-picture-message {
            margin-top: 10px;
            color: #555;
        }

        .profile-webcam-modal {
            position: fixed;
            inset: 0;
            z-index: 9999;
        }

        .profile-webcam-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
        }

        .profile-webcam-content {
            position: relative;
            max-width: 560px;
            margin: 60px auto;
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            z-index: 10000;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .25);
        }

        .profile-webcam-header,
        .profile-webcam-footer {
            padding: 12px 16px;
            border-bottom: 1px solid #ddd;
        }

        .profile-webcam-footer {
            border-top: 1px solid #ddd;
            border-bottom: none;
            text-align: right;
        }

        .profile-webcam-body {
            padding: 16px;
            text-align: center;
        }

        .profile-webcam-close-button {
            float: right;
            border: none;
            background: transparent;
            font-size: 26px;
            line-height: 1;
            cursor: pointer;
        }

        .profile-webcam-video,
        .profile-webcam-preview {
            width: 100%;
            max-width: 480px;
            border-radius: 6px;
            background: #000;
        }

        .profile-webcam-message {
            margin-top: 10px;
            color: #555;
        }
    </style>

    <script>
        var uploadProfilePictureUrl = '@uploadProfilePictureUrl';
        var maxProfilePictureSize = 5 * 1024 * 1024;

        var profileWebcamState = {
            stream: null,
            capturedBlob: null
        };

        function getRequestVerificationToken() {
            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : "";
        }

        function setProfilePictureMessage(message) {
            var messageElement = document.getElementById("profilePictureMessage");
            if (messageElement) {
                messageElement.innerText = message;
            }
        }

        function setProfileWebcamMessage(message) {
            var messageElement = document.getElementById("profileWebcamMessage");
            if (messageElement) {
                messageElement.innerText = message;
            }
        }

        function setProfileButtonsDisabled(disabled) {
            var uploadButton = document.getElementById("profileUploadButton");
            var cameraButton = document.getElementById("profileCameraButton");
            var webcamUploadButton = document.getElementById("profileWebcamUploadButton");
            var captureButton = document.getElementById("profileCaptureButton");

            if (uploadButton) uploadButton.disabled = disabled;
            if (cameraButton) cameraButton.disabled = disabled;
            if (webcamUploadButton) webcamUploadButton.disabled = disabled;
            if (captureButton) captureButton.disabled = disabled;
        }

        function showProfilePicturePreview(blobOrFile) {
            var profilePicture = document.getElementById("profilePicture");
            var placeholder = document.getElementById("profilePicturePlaceholder");

            if (profilePicture) {
                profilePicture.src = window.URL.createObjectURL(blobOrFile);
                profilePicture.style.display = "block";
            }

            if (placeholder) {
                placeholder.style.display = "none";
            }
        }

        function isValidImageFile(file, messageSetter) {
            if (!file) {
                messageSetter("Profile picture file is required.");
                return false;
            }

            if (file.size > maxProfilePictureSize) {
                messageSetter("Profile picture must be 5MB or smaller.");
                return false;
            }

            if (file.type && !file.type.startsWith("image/")) {
                messageSetter("Only image files are allowed.");
                return false;
            }

            return true;
        }

        function openProfileFileUpload(event) {
            if (event) {
                event.preventDefault();
                event.stopPropagation();

                if (event.stopImmediatePropagation) {
                    event.stopImmediatePropagation();
                }
            }

            var input = document.getElementById("profilePictureFileInput");

            if (input) {
                input.value = "";
                input.click();
            }

            return false;
        }

        async function uploadProfilePictureBlob(blob, fileName, messageSetter) {
            if (!isValidImageFile(blob, messageSetter)) {
                return false;
            }

            var formData = new FormData();
            formData.append("profilePicture", blob, fileName);

            messageSetter("Uploading photo...");
            setProfileButtonsDisabled(true);

            try {
                var response = await fetch(uploadProfilePictureUrl, {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken": getRequestVerificationToken()
                    },
                    body: formData
                });

                if (!response.ok) {
                    var errorText = await response.text();
                    messageSetter(errorText || "Photo upload failed.");
                    return false;
                }

                messageSetter("Photo uploaded successfully.");
                return true;
            } catch (error) {
                messageSetter("Photo upload failed.");
                return false;
            } finally {
                setProfileButtonsDisabled(false);
            }
        }

        async function uploadProfilePictureFromFile(input) {
            if (!input || !input.files || input.files.length === 0) {
                return;
            }

            var file = input.files[0];

            if (!isValidImageFile(file, setProfilePictureMessage)) {
                return;
            }

            showProfilePicturePreview(file);

            var uploaded = await uploadProfilePictureBlob(
                file,
                file.name || "profile-photo.jpg",
                setProfilePictureMessage
            );

            if (uploaded) {
                window.location.reload();
            }
        }

        async function openProfileWebcamCapture(event) {
            if (event) {
                event.preventDefault();
                event.stopPropagation();

                if (event.stopImmediatePropagation) {
                    event.stopImmediatePropagation();
                }
            }

            var modal = document.getElementById("profileWebcamModal");
            var video = document.getElementById("profileWebcamVideo");
            var preview = document.getElementById("profileWebcamPreview");

            if (!modal || !video || !preview) {
                return false;
            }

            setProfileWebcamMessage("Starting camera...");

            modal.style.display = "block";
            preview.style.display = "none";
            preview.src = "";
            video.style.display = "block";

            try {
                var stream = await navigator.mediaDevices.getUserMedia({
                    video: true,
                    audio: false
                });

                profileWebcamState.stream = stream;
                profileWebcamState.capturedBlob = null;

                video.srcObject = stream;
                setProfileWebcamMessage("Camera is ready.");
            } catch (error) {
                setProfileWebcamMessage("Unable to access the camera. Please allow camera permission and use HTTPS.");
            }

            return false;
        }

        function captureProfileWebcamPhoto() {
            var video = document.getElementById("profileWebcamVideo");
            var canvas = document.getElementById("profileWebcamCanvas");
            var preview = document.getElementById("profileWebcamPreview");

            if (!video || !canvas || !preview || !video.srcObject) {
                setProfileWebcamMessage("Camera is not ready.");
                return;
            }

            var width = video.videoWidth || 480;
            var height = video.videoHeight || 360;

            canvas.width = width;
            canvas.height = height;

            var context = canvas.getContext("2d");
            context.drawImage(video, 0, 0, width, height);

            canvas.toBlob(function (blob) {
                if (!blob) {
                    setProfileWebcamMessage("Unable to capture photo.");
                    return;
                }

                profileWebcamState.capturedBlob = blob;

                preview.src = URL.createObjectURL(blob);
                preview.style.display = "block";
                video.style.display = "none";

                setProfileWebcamMessage("Photo captured. Review it and click Upload Photo.");
            }, "image/jpeg", 0.9);
        }

        async function uploadProfileWebcamPhoto() {
            if (!profileWebcamState.capturedBlob) {
                setProfileWebcamMessage("Please capture a photo first.");
                return;
            }

            var uploaded = await uploadProfilePictureBlob(
                profileWebcamState.capturedBlob,
                "webcam-profile-photo.jpg",
                setProfileWebcamMessage
            );

            if (uploaded) {
                showProfilePicturePreview(profileWebcamState.capturedBlob);
                closeProfileWebcamCapture();
                window.location.reload();
            }
        }

        function closeProfileWebcamCapture() {
            var modal = document.getElementById("profileWebcamModal");
            var video = document.getElementById("profileWebcamVideo");
            var preview = document.getElementById("profileWebcamPreview");

            if (profileWebcamState.stream) {
                profileWebcamState.stream.getTracks().forEach(function (track) {
                    track.stop();
                });
            }

            profileWebcamState.stream = null;
            profileWebcamState.capturedBlob = null;

            if (video) {
                video.srcObject = null;
            }

            if (preview) {
                preview.src = "";
                preview.style.display = "none";
            }

            if (modal) {
                modal.style.display = "none";
            }

            setProfileWebcamMessage("");
        }
    </script>
}